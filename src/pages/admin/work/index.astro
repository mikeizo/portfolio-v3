---
import type { WorkType } from '@/types/portfolio'

import { getDataFeed } from '@/utils/api'

import Admin from '@/layouts/Admin.astro'
import AdminWorkList from '@/components/admin/pages/work/AdminWorkList.vue'

const workData: WorkType[] = await getDataFeed('work', 'weight', 'asc')
const path = Astro.url.pathname
---

<Admin>
  <AdminWorkList data={workData} path={path} client:load />
</Admin>
