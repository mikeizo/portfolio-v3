---
import { getDataById } from '@/utils/api'

import Admin from '@/layouts/Admin.astro'
import WorkForm from '@/components/admin/pages/work/WorkForm.vue'

const { id } = Astro.params
const workData = await getDataById('work', id)
---

<Admin>
  <WorkForm data={workData} id={id} client:load />
</Admin>
