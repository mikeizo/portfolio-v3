---
import { getDataById } from '@/utils/api'

import Admin from '@/layouts/Admin.astro'
import AdminWorkForm from '@/components/admin/pages/work/AdminWorkForm.vue'

const { id } = Astro.params
const workData = await getDataById('work', id)
---

<Admin>
  <AdminWorkForm data={workData} id={id} client:load />
</Admin>
