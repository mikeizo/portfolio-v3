---
import { getDataById } from '@/utils/api'

import AdminAboutForm from '@/components/admin/pages/about/AdminAboutForm.vue'
import Admin from '@/layouts/Admin.astro'

const { id } = Astro.params
const aboutData = await getDataById('about', id)
---

<Admin>
  <AdminAboutForm data={aboutData} id={id} client:load />
</Admin>
